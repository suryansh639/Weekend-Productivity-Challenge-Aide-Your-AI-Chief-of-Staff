# ─── Aide configuration ──────────────────────────────────────────────────────
# All values have safe local defaults. Set these to switch to real AWS.

# Providers: "mock" (offline, deterministic) or "bedrock"
AIDE_LLM_PROVIDER=mock
# Store backend: "local" (JSON file) or "dynamo"
AIDE_STORE_BACKEND=local

# Local store file (used when AIDE_STORE_BACKEND=local)
AIDE_LOCAL_DB_PATH=.aide_data.json

# ─── AWS / Bedrock (used when providers are set to bedrock/dynamo) ────────────
AWS_REGION=us-east-1
# Claude on Bedrock (inference profile or model id)
AIDE_BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0
AIDE_BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
AIDE_DYNAMO_TABLE=aide

# ─── Behaviour tuning ─────────────────────────────────────────────────────────
# A thread with no reply after this many days triggers a proactive nudge draft.
AIDE_NUDGE_STALE_DAYS=3
# Owner identity Aide acts on behalf of.
AIDE_OWNER_EMAIL=you@example.com
AIDE_OWNER_NAME=You

# CORS origins for the SPA (comma separated)
AIDE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
